# Ignore large data and env for Vercel static deploy
.venv/
data/
runs/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.log
.env
.env.local
.git/
.DS_Store
*.npy
*.jsonl
node_modules/

# ---- Prevent Vercel from auto-detecting a Python project ----
# The root requirements.txt (torch/gradio/sentence-transformers) made Vercel run a
# multi-GB CUDA/torch install during build, which blew past limits and served HTTP 500.
# This is a static-only deploy (artifacts/), so exclude all Python surfaces.
requirements.txt
setup.sh
ui/
packages/
scripts/
fixtures/
*.py
